SPECIALIST_HOST=127.0.0.1
SPECIALIST_PORT=9999

# Phase 1+ gateway (the real Specialist above is what it forwards to)
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8080

# Where the Coordinator sends discovery + task requests. Leave unset to talk to the
# Specialist directly (Phase 0 behavior). Set to the gateway to route through it (Phase 1+).
# COORDINATOR_TARGET_URL=http://127.0.0.1:8080
